{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1thnNYlIST_mVzxEhLQc43IqVcSZZCUsq","timestamp":1772820189939}],"gpuType":"T4","authorship_tag":"ABX9TyPAWfk5uqJrTzRR04c8MYtH"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"},"accelerator":"GPU"},"cells":[{"cell_type":"markdown","source":["Бинарная классификация ТС: грузовой / легковой"],"metadata":{"id":"Lc9At8XIPx07"}},{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZnixnDaPPZtL","executionInfo":{"status":"ok","timestamp":1772819549934,"user_tz":-300,"elapsed":30926,"user":{"displayName":"Антон","userId":"08057564651697880658"}},"outputId":"2782cb09-ed03-4558-ffcc-13d493d08122"},"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}],"source":["# 1 Загрузка и распаковка\n","from google.colab import drive\n","drive.mount('/content/drive')\n","\n","import zipfile, os, shutil\n","\n","with zipfile.ZipFile('/content/drive/MyDrive/Данные/archive.zip', 'r') as z:\n","    z.extractall('/content/dataset_raw')"]},{"cell_type":"code","source":["# 2 Перегруппировка в 2 класса\n","\"\"\"\n","Оригинальные классы:  car, truck, bus, motorcycle, train(ЖД)\n","Новая группировка:\n","  truck             → truck/  (грузовой)\n","  car + bus + motorcycle  → car/   (легковой/не-грузовой)\n","  train (ЖД)        → ПРОПУСКАЕМ (не нужен)\n","\"\"\"\n","\n","RAW_ROOT = '/content/dataset_raw/dataset'\n","NEW_ROOT = '/content/dataset'\n","\n","# Маппинг: оригинальный класс → новый класс\n","CLASS_MAP = {\n","    'truck':      'truck',       # грузовой\n","    'car':        'car',         # легковой\n","    'bus':        'car',         # автобус → легковой (не въезжает)\n","    'motorcycle': 'car',         # мотоцикл → легковой (не въезжает)\n","    'train':      None,          # ЖД поезд → пропустить\n","}\n","\n","def reorganize(split_name):\n","    src_split = os.path.join(RAW_ROOT, split_name)\n","    dst_split = os.path.join(NEW_ROOT, split_name)\n","\n","    counts = {'truck': 0, 'car': 0, 'skipped': 0}\n","\n","    for orig_class, new_class in CLASS_MAP.items():\n","        src_class_dir = os.path.join(src_split, orig_class)\n","        if not os.path.exists(src_class_dir):\n","            continue\n","\n","        if new_class is None:\n","            counts['skipped'] += len(os.listdir(src_class_dir))\n","            continue\n","\n","        dst_class_dir = os.path.join(dst_split, new_class)\n","        os.makedirs(dst_class_dir, exist_ok=True)\n","\n","        for fname in os.listdir(src_class_dir):\n","            src_file = os.path.join(src_class_dir, fname)\n","            # Добавляем префикс чтобы не было конфликтов имён\n","            dst_file = os.path.join(dst_class_dir, f\"{orig_class}_{fname}\")\n","            shutil.copy2(src_file, dst_file)\n","            counts[new_class] += 1\n","\n","    print(f\"  {split_name}: truck={counts['truck']}, car={counts['car']}, пропущено={counts['skipped']}\")\n","\n","print(\"Перегруппировка датасета...\")\n","reorganize('train')\n","reorganize('validation')\n","reorganize('test')\n","print(\"✅ Готово\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Z5rXLJ4QPtBN","executionInfo":{"status":"ok","timestamp":1772819575930,"user_tz":-300,"elapsed":784,"user":{"displayName":"Антон","userId":"08057564651697880658"}},"outputId":"f0faf950-e360-4470-f93c-626db705b3a3"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Перегруппировка датасета...\n","  train: truck=908, car=3194, пропущено=1319\n","  validation: truck=100, car=427, пропущено=182\n","  test: truck=100, car=426, пропущено=182\n","✅ Готово\n"]}]},{"cell_type":"code","source":["# 3 Проверка баланса классов\n","import matplotlib.pyplot as plt\n","\n","for split in ['train', 'validation', 'test']:\n","    split_path = os.path.join(NEW_ROOT, split)\n","    print(f\"\\n{split}:\")\n","    for cls in ['car', 'truck']:\n","        cls_path = os.path.join(split_path, cls)\n","        n = len(os.listdir(cls_path)) if os.path.exists(cls_path) else 0\n","        bar = '█' * (n // 50)\n","        print(f\"  {cls:6}: {n:5} фото  {bar}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"mdZFM3LQPu20","executionInfo":{"status":"ok","timestamp":1772819582531,"user_tz":-300,"elapsed":10,"user":{"displayName":"Антон","userId":"08057564651697880658"}},"outputId":"87ef5bfc-98eb-43cd-a6ad-7dc466031997"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","train:\n","  car   :  3194 фото  ███████████████████████████████████████████████████████████████\n","  truck :   908 фото  ██████████████████\n","\n","validation:\n","  car   :   427 фото  ████████\n","  truck :   100 фото  ██\n","\n","test:\n","  car   :   426 фото  ████████\n","  truck :   100 фото  ██\n"]}]},{"cell_type":"code","source":["# 4 Обучение (ResNet18, Transfer Learning)\n","import torch\n","import torch.nn as nn\n","from torchvision import datasets, transforms, models\n","from torch.utils.data import DataLoader\n","\n","device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","print(f\"\\nУстройство: {device}\")\n","\n","CLASSES   = ['car', 'truck']   # 0=легковой, 1=грузовой\n","IMG_SIZE  = 224\n","BATCH     = 32\n","EPOCHS    = 10\n","LR        = 0.001\n","\n","train_tfm = transforms.Compose([\n","    transforms.Resize((IMG_SIZE, IMG_SIZE)),\n","    transforms.RandomHorizontalFlip(),\n","    transforms.RandomRotation(10),\n","    transforms.ColorJitter(brightness=0.2, contrast=0.2),\n","    transforms.ToTensor(),\n","    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])\n","])\n","val_tfm = transforms.Compose([\n","    transforms.Resize((IMG_SIZE, IMG_SIZE)),\n","    transforms.ToTensor(),\n","    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])\n","])\n","\n","train_ds = datasets.ImageFolder(f'{NEW_ROOT}/train',      train_tfm)\n","val_ds   = datasets.ImageFolder(f'{NEW_ROOT}/validation', val_tfm)\n","test_ds  = datasets.ImageFolder(f'{NEW_ROOT}/test',       val_tfm)\n","\n","train_dl = DataLoader(train_ds, batch_size=BATCH, shuffle=True,  num_workers=2)\n","val_dl   = DataLoader(val_ds,   batch_size=BATCH, shuffle=False, num_workers=2)\n","test_dl  = DataLoader(test_ds,  batch_size=BATCH, shuffle=False, num_workers=2)\n","\n","print(f\"Train: {len(train_ds)} | Val: {len(val_ds)} | Test: {len(test_ds)}\")\n","print(f\"Классы: {train_ds.classes}\")\n","\n","# ResNet18 — только дообучаем последний слой\n","model = models.resnet18(pretrained=True)\n","for p in model.parameters():\n","    p.requires_grad = False\n","model.fc = nn.Linear(model.fc.in_features, 2)  # 2 класса!\n","model = model.to(device)\n","\n","criterion = nn.CrossEntropyLoss()\n","optimizer = torch.optim.Adam(model.fc.parameters(), lr=LR)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LhXptLUFPu_t","executionInfo":{"status":"ok","timestamp":1772819608594,"user_tz":-300,"elapsed":12890,"user":{"displayName":"Антон","userId":"08057564651697880658"}},"outputId":"6b5d8c86-7adb-4be3-9563-9dcc55f1bcde"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Устройство: cuda\n","Train: 4100 | Val: 527 | Test: 526\n","Классы: ['car', 'truck']\n","Downloading: \"https://download.pytorch.org/models/resnet18-f37072fd.pth\" to /root/.cache/torch/hub/checkpoints/resnet18-f37072fd.pth\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/torchvision/models/_utils.py:208: UserWarning: The parameter 'pretrained' is deprecated since 0.13 and may be removed in the future, please use 'weights' instead.\n","  warnings.warn(\n","/usr/local/lib/python3.12/dist-packages/torchvision/models/_utils.py:223: UserWarning: Arguments other than a weight enum or `None` for 'weights' are deprecated since 0.13 and may be removed in the future. The current behavior is equivalent to passing `weights=ResNet18_Weights.IMAGENET1K_V1`. You can also use `weights=ResNet18_Weights.DEFAULT` to get the most up-to-date weights.\n","  warnings.warn(msg)\n","100%|██████████| 44.7M/44.7M [00:00<00:00, 203MB/s]\n"]}]},{"cell_type":"code","source":["# 5 Цикл обучения\n","history = {'train_acc': [], 'val_acc': [], 'train_loss': [], 'val_loss': []}\n","best_acc = 0\n","\n","print(f\"\\n{'Эп':>3} | {'Train Loss':>10} | {'Train Acc':>9} | {'Val Acc':>8} |\")\n","print(\"-\" * 45)\n","\n","for epoch in range(EPOCHS):\n","    # Train\n","    model.train()\n","    tr_loss, tr_correct, tr_total = 0, 0, 0\n","    for imgs, labels in train_dl:\n","        imgs, labels = imgs.to(device), labels.to(device)\n","        optimizer.zero_grad()\n","        out = model(imgs)\n","        loss = criterion(out, labels)\n","        loss.backward()\n","        optimizer.step()\n","        tr_loss    += loss.item()\n","        tr_correct += (out.argmax(1) == labels).sum().item()\n","        tr_total   += labels.size(0)\n","\n","    # Val\n","    model.eval()\n","    vl_loss, vl_correct, vl_total = 0, 0, 0\n","    with torch.no_grad():\n","        for imgs, labels in val_dl:\n","            imgs, labels = imgs.to(device), labels.to(device)\n","            out  = model(imgs)\n","            loss = criterion(out, labels)\n","            vl_loss    += loss.item()\n","            vl_correct += (out.argmax(1) == labels).sum().item()\n","            vl_total   += labels.size(0)\n","\n","    tr_acc = tr_correct / tr_total\n","    vl_acc = vl_correct / vl_total\n","    history['train_acc'].append(tr_acc)\n","    history['val_acc'].append(vl_acc)\n","    history['train_loss'].append(tr_loss / len(train_dl))\n","    history['val_loss'].append(vl_loss / len(val_dl))\n","\n","    mark = ''\n","    if vl_acc > best_acc:\n","        best_acc = vl_acc\n","        torch.save(model.state_dict(), '/content/vehicle_binary_best.pth')\n","        mark = ' ← сохранено'\n","\n","    print(f\"{epoch+1:>3} | {tr_loss/len(train_dl):>10.4f} | {tr_acc:>8.1%} | {vl_acc:>7.1%} |{mark}\")\n","\n","print(f\"\\n✅ Лучшая Val Accuracy: {best_acc:.1%}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"QZXD1dOYQaxc","executionInfo":{"status":"ok","timestamp":1772819847153,"user_tz":-300,"elapsed":228681,"user":{"displayName":"Антон","userId":"08057564651697880658"}},"outputId":"ea1d78e7-ebe4-40cb-b830-ab7600f8328e"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["\n"," Эп | Train Loss | Train Acc |  Val Acc |\n","---------------------------------------------\n","  1 |     0.3776 |    84.1% |   91.7% | ← сохранено\n","  2 |     0.2957 |    88.0% |   91.1% |\n","  3 |     0.2705 |    88.6% |   88.0% |\n","  4 |     0.2724 |    88.7% |   90.5% |\n","  5 |     0.2678 |    89.0% |   91.1% |\n","  6 |     0.2652 |    89.4% |   91.8% | ← сохранено\n","  7 |     0.2490 |    90.3% |   92.2% | ← сохранено\n","  8 |     0.2453 |    90.1% |   90.1% |\n","  9 |     0.2607 |    89.6% |   91.5% |\n"," 10 |     0.2499 |    89.9% |   91.5% |\n","\n","✅ Лучшая Val Accuracy: 92.2%\n"]}]},{"cell_type":"code","source":["# 6 Итоговый тест + метрики\n","from sklearn.metrics import classification_report, confusion_matrix\n","import seaborn as sns\n","import numpy as np\n","\n","model.load_state_dict(torch.load('/content/vehicle_binary_best.pth'))\n","model.eval()\n","\n","all_preds, all_labels = [], []\n","with torch.no_grad():\n","    for imgs, labels in test_dl:\n","        out = model(imgs.to(device))\n","        all_preds.extend(out.argmax(1).cpu().numpy())\n","        all_labels.extend(labels.numpy())\n","\n","labels_ru = ['Легковой', 'Грузовой']\n","print(\"\\n📊 ФИНАЛЬНЫЙ ОТЧЁТ (Test set):\")\n","print(classification_report(all_labels, all_preds, target_names=labels_ru))\n","\n","# Графики для диплома\n","fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n","\n","# 1. Loss\n","axes[0].plot(history['train_loss'], 'b-o', label='Train', markersize=4)\n","axes[0].plot(history['val_loss'],   'r-o', label='Val',   markersize=4)\n","axes[0].set_title('Функция потерь (Loss)', fontsize=13)\n","axes[0].set_xlabel('Эпоха'); axes[0].set_ylabel('Loss')\n","axes[0].legend(); axes[0].grid(alpha=0.3)\n","\n","# 2. Accuracy\n","axes[1].plot([a*100 for a in history['train_acc']], 'b-o', label='Train', markersize=4)\n","axes[1].plot([a*100 for a in history['val_acc']],   'r-o', label='Val',   markersize=4)\n","axes[1].set_title('Точность (Accuracy)', fontsize=13)\n","axes[1].set_xlabel('Эпоха'); axes[1].set_ylabel('Accuracy (%)')\n","axes[1].legend(); axes[1].grid(alpha=0.3)\n","\n","# 3. Confusion Matrix\n","cm = confusion_matrix(all_labels, all_preds)\n","sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[2],\n","            xticklabels=labels_ru, yticklabels=labels_ru)\n","axes[2].set_title('Матрица ошибок', fontsize=13)\n","axes[2].set_ylabel('Истинный класс')\n","axes[2].set_xlabel('Предсказанный класс')\n","\n","plt.tight_layout()\n","plt.savefig('/content/vehicle_binary_results.png', dpi=150, bbox_inches='tight')\n","plt.show()\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":683},"id":"CFK0IMdpPvIM","executionInfo":{"status":"ok","timestamp":1772819858590,"user_tz":-300,"elapsed":5948,"user":{"displayName":"Антон","userId":"08057564651697880658"}},"outputId":"49cab7bd-a169-4095-d4a7-445b241ff869"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","📊 ФИНАЛЬНЫЙ ОТЧЁТ (Test set):\n","              precision    recall  f1-score   support\n","\n","    Легковой       0.94      0.97      0.95       426\n","    Грузовой       0.84      0.72      0.77       100\n","\n","    accuracy                           0.92       526\n","   macro avg       0.89      0.84      0.86       526\n","weighted avg       0.92      0.92      0.92       526\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x500 with 4 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# 7 Сохранить модель с метаданными\n","torch.save({\n","    'model_state_dict': model.state_dict(),\n","    'classes': CLASSES,          # ['car', 'truck']\n","    'classes_ru': labels_ru,     # ['Легковой', 'Грузовой']\n","    'img_size': IMG_SIZE,\n","    'best_val_acc': best_acc,\n","    'description': 'Бинарный классификатор ТС для СКУД'\n","}, '/content/vehicle_binary_final.pth')\n","\n","from google.colab import files\n","files.download('/content/vehicle_binary_final.pth')\n","files.download('/content/vehicle_binary_results.png')\n","print(\"✅ Всё скачано!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":34},"id":"sZcsiwYrPvVs","executionInfo":{"status":"ok","timestamp":1772819879981,"user_tz":-300,"elapsed":68,"user":{"displayName":"Антон","userId":"08057564651697880658"}},"outputId":"b006e369-79a4-4681-9252-e5931bed22ad"},"execution_count":7,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_d09c07d1-3f76-4b41-9e43-cdc556c6439e\", \"vehicle_binary_final.pth\", 44791371)"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["\n","    async function download(id, filename, size) {\n","      if (!google.colab.kernel.accessAllowed) {\n","        return;\n","      }\n","      const div = document.createElement('div');\n","      const label = document.createElement('label');\n","      label.textContent = `Downloading \"${filename}\": `;\n","      div.appendChild(label);\n","      const progress = document.createElement('progress');\n","      progress.max = size;\n","      div.appendChild(progress);\n","      document.body.appendChild(div);\n","\n","      const buffers = [];\n","      let downloaded = 0;\n","\n","      const channel = await google.colab.kernel.comms.open(id);\n","      // Send a message to notify the kernel that we're ready.\n","      channel.send({})\n","\n","      for await (const message of channel.messages) {\n","        // Send a message to notify the kernel that we're ready.\n","        channel.send({})\n","        if (message.buffers) {\n","          for (const buffer of message.buffers) {\n","            buffers.push(buffer);\n","            downloaded += buffer.byteLength;\n","            progress.value = downloaded;\n","          }\n","        }\n","      }\n","      const blob = new Blob(buffers, {type: 'application/binary'});\n","      const a = document.createElement('a');\n","      a.href = window.URL.createObjectURL(blob);\n","      a.download = filename;\n","      div.appendChild(a);\n","      a.click();\n","      div.remove();\n","    }\n","  "]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.Javascript object>"],"application/javascript":["download(\"download_3a2e7ce4-9d69-46cd-8fd4-9aff5430a549\", \"vehicle_binary_results.png\", 143714)"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["✅ Всё скачано!\n"]}]}]}